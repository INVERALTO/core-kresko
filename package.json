{
  "name": "kresko-core",
  "version": "0.1.0",
  "type": "module", 
  "description": "Core multi-tenant de Kresko...",
  "main": "dist/app.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/app.ts",
    "dev:admin": "tsx watch src/server.ts", 
    "build": "tsc",
    "start": "node dist/app.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "dotenv": "^17.4.2",
    "express": "^4.19.2",
    "pg": "^8.22.0",
    "tsx": "^4.16.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.9",
    "@types/pg": "^8.20.0",
    "prisma": "^7.8.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.3"
  }
}